---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

const metadata = {
  title: `Security Blog${currentPage > 1 ? ` — Page ${currentPage}` : ''} — Vuldesk`,
  description: 'Web application security research, penetration testing findings, and practical guides for SaaS founders.',
  robots: blogListRobots,
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '/' },
        { text: 'Services', href: '/#services' },
        { text: 'Blog', href: '/blog' },
        { text: 'Contact', href: '/#contact' },
      ]}
      actions={[
        {
          text: 'Free Recon Report',
          href: '/free-recon',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline
      subtitle="Penetration testing findings, API security research, and practical security guides for SaaS founders."
    >
      Security Blog
    </Headline>
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>

  <CallToAction
    title="Free external recon report"
    subtitle="Email us your domain — we'll send your attack surface report within 24 hours."
    actions={[
      {
        variant: 'primary',
        text: 'Get your free report',
        href: '/free-recon',
      },
    ]}
  />
</Layout>
